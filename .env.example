# Database Configuration
DB_NAME=library
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Application Database Configuration
DATABASE_EMBEDDED=false
DATABASE_URL=jdbc:postgresql://postgres:5432/library
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# JWT Configuration
# IMPORTANT: Change this secret in production! Minimum 256 bits required.
JWT_SECRET=your-secret-key-change-in-production-min-256-bits-long
JWT_ISSUER=library-application
JWT_AUDIENCE=library-users
# JWT validity in milliseconds (default: 1 hour = 3600000ms)
JWT_VALIDITY=3600000

# Server Configuration
KTOR_PORT=8080
KTOR_ENV=production

# API Documentation
API_TITLE=Library Management API
API_VERSION=1.0.0
API_DESCRIPTION=A comprehensive Library Management System API

# Java Configuration
JAVA_OPTS=-Xmx512m -Xms256m

# Logging
LOG_LEVEL=INFO
